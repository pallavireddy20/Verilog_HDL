//design code

module xor_gate (
    input  a,
    input  b,
    output y
);

assign y = a ^ b;

endmodule

//testbench code
module xor_gate_tb;

    reg a;
    reg b;
    wire y;

    // Instantiate the DUT (Device Under Test)
    xor_gate uut (
        .a(a),
        .b(b),
        .y(y)
    );
    initial begin
        a = 0; b = 0; #10;
        a = 0; b = 1; #10;
        a = 1; b = 0; #10;
        a = 1; b = 1; #10;

        $finish;
    end

endmodule
